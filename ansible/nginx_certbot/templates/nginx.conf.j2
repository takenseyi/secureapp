{# TODO: Update 'your-domain.com' before deployment #}
server {
    listen 80;
    server_name secureapp.click www.secureapp.click;

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name secureapp.click www.secureapp.click;

    ssl_certificate /etc/letsencrypt/live/secureapp.click/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/secureapp.click/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:5000;  # Flask or Node app
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
