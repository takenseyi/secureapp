server {
    listen 80;
    server_name secureapp.click www.secureapp.click;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name secureapp.click www.secureapp.click;

    ssl_certificate /etc/letsencrypt/live/secureapp.click/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/secureapp.click/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:5000;  # or your Flask port
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
